PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zorvo_iq"
JWT_SECRET="replace_with_long_secret"
CORS_ORIGIN="http://localhost:5173"

# OTP / magic-link email auth
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=30
# Set OTP_DEV_LOG=false to silence console OTP logs in production-like environments.
OTP_DEV_LOG=true

# Optional SMTP transport. Leave SMTP_HOST blank to log codes to the server console only.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Zorvo IQ <no-reply@zorvoiq.example>"

# Stripe (Checkout + webhook). Leave STRIPE_SECRET_KEY blank to disable paid checkout on the API.
APP_URL="http://localhost:5173"
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional explicit return URLs (defaults: APP_URL + "/#/")
# STRIPE_SUCCESS_URL="http://localhost:5173/#/"
# STRIPE_CANCEL_URL="http://localhost:5173/#/"
# Default Price id when the client omits priceId
STRIPE_DEFAULT_PRICE_ID=
