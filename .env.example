# Copy to ".env" locally or set in StackBlitz / CI. Optional — app runs without it; AI screens show a friendly message.
# Either name works (Vite merges both in vite.config.ts):
VITE_GEMINI_API_KEY=
GEMINI_API_KEY=

# Backend API base URL used by the OTP login flow (e.g. http://localhost:4000).
# If unset or unreachable, the login screen falls back to local-only auth.
VITE_API_URL=
# Legacy alias for the same value (used by api/restClient.ts when VITE_API_MODE=rest).
VITE_API_BASE_URL=

# Stripe Checkout (optional). When VITE_STRIPE_PUBLIC_KEY is set, unlock uses POST /api/create-checkout-session (requires VITE_API_MODE=rest + JWT).
VITE_STRIPE_PUBLIC_KEY=
VITE_STRIPE_PRICE_ID=
